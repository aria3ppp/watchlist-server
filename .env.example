# server specific envs
SERVER_LOGFILE=log.txt
SERVER_PORT=8080

TOKEN_SIGNING_KEY=token_signing_key

# postgresql database envs
POSTGRES_USER=watchlist-user
POSTGRES_PASSWORD=watchlist-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=watchlist-db

# environment variable used by elasticsearch client
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX_SERIESES=serieses
ELASTICSEARCH_INDEX_MOVIES=movies